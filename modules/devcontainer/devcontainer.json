{
  "name": "dev (ubuntu)",
  "build": {
    "name": "dev:latest",
    "dockerfile": "Dockerfile",
    "context": "${localScript:../..}"
  },
  "remoteUser": "ubuntu",
  "containerEnv": {
    "GOTOOLCHAIN": "auto",
    "EDITOR": "nvim",
    "PATH": "/home/ubuntu/.local/share/google-cloud-sdk/bin:${containerEnv:PATH}"
  },
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}",
    "TERM": "xterm-256color"
  },
  "postCreateCommand": "~/.dotfiles/modules/devcontainer/scripts/post-create.sh",
  "preExecCommand": "~/.dotfiles/modules/devcontainer/scripts/pre-exec.sh",
  "mounts": [
    "source=${localEnv:HOME}/.claude/.credentials.json,target=/home/ubuntu/.claude/.credentials.json,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude.json,target=/home/ubuntu/.claude.json,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude/plans,target=/home/ubuntu/.claude/plans,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude/projects,target=/home/ubuntu/.claude/projects,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude/sessions,target=/home/ubuntu/.claude/sessions,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude/session-env,target=/home/ubuntu/.claude/session-env,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude/file-history,target=/home/ubuntu/.claude/file-history,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.codex/auth.json,target=/home/ubuntu/.codex/auth.json,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.codex/sessions,target=/home/ubuntu/.codex/sessions,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.codex/memories,target=/home/ubuntu/.codex/memories,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.gemini/oauth_creds.json,target=/home/ubuntu/.gemini/oauth_creds.json,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.gemini/google_accounts.json,target=/home/ubuntu/.gemini/google_accounts.json,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.gemini/memory,target=/home/ubuntu/.gemini/memory,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.config/github-copilot,target=/home/ubuntu/.config/github-copilot,type=bind,consistency=cached",
    "source=/mnt/c/Obsidian,target=/home/ubuntu/Obsidian,type=bind,consistency=cached",
    "source=${localEnv:USERPROFILE}/Downloads,target=/home/ubuntu/Downloads,type=bind,consistency=cached",
    "source=${localEnv:USERPROFILE}/Documents,target=/home/ubuntu/Documents,type=bind,consistency=cached"
  ]
}
