# Claude Code aliases
alias claude='claude --enable-auto-mode'

# Model + effort combinations
alias sonnet-medium='claude --model sonnet --effort medium'
alias sonnet-high='claude --model sonnet --effort high'
alias opus-xhigh='claude --model "opus[1m]" --effort xhigh'
alias opus-max='claude --model "opus[1m]" --effort max'
alias opusplan-high='claude --model opusplan --effort high'
