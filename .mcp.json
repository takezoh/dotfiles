{
  "mcpServers": {
    "chrome-devtools": {
      "type": "stdio",
      "command": "/opt/roost/run/roost-bridge",
      "args": [
        "mcp-exec",
        "chrome-devtools"
      ]
    },
    "playwright": {
      "type": "stdio",
      "command": "/opt/roost/run/roost-bridge",
      "args": [
        "mcp-exec",
        "playwright"
      ]
    }
  }
}
