{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-module.local/docs/plan.schema.json",
  "$comment": "decision_ref: adr-20260714-design-decision-evidence-closure; decision_ref: adr-20260714-design-outcome-evolution-witness-closure; decision_ref: adr-20260714-design-decision-input-closure",
  "title": "Implementation plan (Spec-Kit compatible)",
  "allOf": [{"$ref": "_common.schema.json"}],
  "type": "object",
  "unevaluatedProperties": false,
  "required": ["goal"],
  "properties": {
    "kind":   {"const": "plan"},
    "status": {"enum": ["draft", "active", "done", "abandoned"]},
    "goal":   {"type": "string", "minLength": 1},
    "scope_in":  {"type": "array", "items": {"type": "string"}},
    "scope_out": {"type": "array", "items": {"type": "string"}},
    "spec_ids": {
      "type": "array",
      "items": {"type": "string", "pattern": "^spec-[0-9]{8}-[a-z0-9][a-z0-9-]*$"},
      "uniqueItems": true,
      "description": "Spec ids this plan implements. Mirrors spec.plan for many-to-many."
    },
    "milestones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "status"],
        "additionalProperties": false,
        "properties": {
          "id":     {"type": "string", "pattern": "^m[0-9]+$"},
          "title":  {"type": "string", "minLength": 1},
          "status": {"enum": ["todo", "in_progress", "done", "cancelled"]}
        }
      }
    },
    "adrs": {
      "type": "array",
      "items": {"type": "string", "pattern": "^adr-[0-9]{8}-[a-z0-9][a-z0-9-]*$"}
    },
    "decision_dispositions": {
      "type": "array",
      "description": "canonical design planからmaterializeした上流decision inputの最終disposition。",
      "items": {
        "type": "object",
        "required": ["decision_input_ref", "disposition", "rationale", "adr_refs", "contract_refs"],
        "additionalProperties": false,
        "properties": {
          "decision_input_ref": {"type": "string", "pattern": "^decision-input-[a-z0-9-]+$"},
          "disposition": {"enum": ["adopted", "rejected", "subsumed", "not_applicable", "implementation_detail"]},
          "rationale": {"type": "string", "minLength": 1},
          "adr_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^adr-[0-9]{8}-[a-z0-9][a-z0-9-]*$"}},
          "contract_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^contract-[a-z0-9-]+$"}},
          "implementation_decision_ref": {"type": "string", "minLength": 1},
          "subsumed_by": {"type": "string", "pattern": "^decision-input-[a-z0-9-]+$"}
        }
      }
    },
    "tasks": {
      "type": "array",
      "items": {"type": "string", "pattern": "^task-[0-9]{8}-[a-z0-9][a-z0-9-]*$"}
    },
    "contracts": {
      "type": "array",
      "items": {"type": "string"}
    },
    "contract_projections": {
      "type": "array",
      "description": "canonical design planからmaterializeしたcontract内部stable IDのprojection",
      "items": {
        "type": "object",
        "required": ["id", "decision_rules", "observable_effects", "operational_inputs", "semantic_profiles", "failures", "verifications", "witnesses"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "pattern": "^contract-[a-z0-9-]+$"},
          "decision_rules": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^decision-[a-z0-9-]+$"}},
          "observable_effects": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^observable-[a-z0-9-]+$"}},
          "operational_inputs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^input-[a-z0-9-]+$"}},
          "semantic_profiles": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^profile-[a-z0-9-]+$"}},
          "failures": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^failure-[a-z0-9-]+$"}},
          "verifications": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^verify-[a-z0-9-]+$"}},
          "witnesses": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^witness-[a-z0-9-]+$"}}
        }
      }
    },
    "reference_algorithms": {
      "type": "array",
      "description": "[x-tentative] spec-detail (2026-07-09): Reference Algorithms 節 (optional). pseudocode を plan.md 内独立節に集約し milestone は id 参照のみで再利用 (adr-20260709-reference-algorithms-in-plan)。algorithms.md 独立 kind 化は future work。skills/design/knowledge/artifact-semantics.md §11 が SoT。廃止基準: 2027-01-09 までに spec-detail 以外で 2 plan 以上が使わなければ削除",
      "items": {
        "type": "object",
        "required": ["id"],
        "additionalProperties": false,
        "properties": {
          "id":      {"type": "string", "pattern": "^alg-[a-z0-9][a-z0-9-]*$", "description": "milestone 本文からの id 参照先"},
          "purpose": {"type": "string", "description": "1 行で目的"}
        }
      }
    },
    "verification_profiles": {
      "type": "array",
      "description": "[x-tentative] spec-detail (2026-07-09): Verification profile 拡張 (optional). Tier / 実行コマンド verbatim / 判定基準 / milestone 完了判定 (DoD) の 4 列。skills/design/knowledge/artifact-semantics.md §11 が SoT (FR-002)。廃止基準: 2027-01-09 までに spec-detail 以外で 2 plan 以上が使わなければ削除",
      "items": {
        "type": "object",
        "required": ["profile", "tier", "command", "criterion"],
        "additionalProperties": false,
        "properties": {
          "profile":         {"type": "string", "minLength": 1},
          "milestone":       {"type": "string", "pattern": "^m[0-9]+$"},
          "tier":            {"enum": ["T0", "T1", "T2", "T3"]},
          "command":         {"type": "string", "minLength": 1, "description": "verbatim 実行コマンド"},
          "criterion":       {"type": "string", "minLength": 1},
          "milestone_dod":   {"type": "string", "description": "milestone 完了判定 (DoD) — 空なら criterion と同一とみなす"}
        }
      }
    },
    "implementation_checklist": {
      "type": "object",
      "description": "[x-tentative] spec-detail (2026-07-09): Implementation Checklist (optional). Symphony §18 の REQUIRED / RECOMMENDED / Operational 3 層 (FR-002)。milestone.status: done とは独立 (milestone = 工程 / checklist = 完了要件)。廃止基準: 2027-01-09 までに spec-detail 以外で 2 plan 以上が使わなければ削除",
      "additionalProperties": false,
      "properties": {
        "required":    {"type": "array", "items": {"type": "string", "minLength": 1}},
        "recommended": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "operational": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    }
  }
}
